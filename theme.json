{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"layout": {
			"contentSize": "1200px",
			"wideSize": "1440px"
		},
		"color": {
			"custom": true,
			"customDuotone": false,
			"customGradient": false,
			"defaultDuotone": false,
			"defaultGradients": false,
			"defaultPalette": false,
			"palette": []
		},
		"typography": {
			"customFontSize": true,
			"dropCap": false,
			"fontStyle": false,
			"fontWeight": true,
			"letterSpacing": false,
			"lineHeight": true,
			"textDecoration": false,
			"textTransform": false,
			"writingMode": false,
			"fontFamilies": [],
			"fontSizes": []
		},
		"spacing": {
			"customSpacingSize": true,
			"units": ["px", "rem", "em", "%", "vh", "vw"]
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		}
	},
	"styles": {},
	"customTemplates": [],
	"templateParts": []
}
